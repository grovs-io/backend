<title><%= @page_title %></title>

<meta property="og:title" content="<%= @page_title %>">
<meta property="og:description" content="<%= @page_subtitle %>">

<meta property="og:image" content="<%=@page_image %>">
<meta property="og:type" content="website"> <!-- Type of content -->
<meta property="og:url" content="<%=@page_full_path%>">

 <!-- Twitter specific meta tags -->
<meta name="twitter:card" content="<%=@page_image %>">
<meta name="twitter:title" content="<%= @page_title %>">
<meta name="twitter:description" content="<%= @page_subtitle %>">
<meta name="twitter:image" content="<%=@page_image %>">

<meta name="viewport" content="width=device-width, initial-scale=1">
