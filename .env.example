# =============================================================================
# Linksquared Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (React Dashboard)
# -----------------------------------------------------------------------------
REACT_HOST_PROTOCOL=http://
REACT_HOST=localhost:3001
REACT_HOST_CHANGE_PASSWORD_PATH=/new-password
REACT_HOST_ACCEPT_INVITE_PATH=/accept-invite
REACT_HOST_DASHBOARD_PATH=/

# Beta dashboard (optional)
# REACT_BETA_HOST_PROTOCOL=https://
# REACT_BETA_HOST=beta.example.com

# -----------------------------------------------------------------------------
# Server / Backend
# -----------------------------------------------------------------------------
SERVER_HOST_PROTOCOL=http://
SERVER_HOST=localhost:3000

# Domain configuration
# DOMAIN_LIVE=sqd.link        # defaults to sqd.link if not set
# DOMAIN_TEST=test-sqd.link   # defaults to test-sqd.link if not set

# Preview URL for link previews
PREVIEW_BASE_URL=http://preview.lvh.me:3000

# SSO failure redirect
# SSO_AUTHENTICATION_ENDPOINT=http://localhost:3001/login

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# For production, set DATABASE_URL instead:
# DATABASE_URL=postgres://user:password@host:5432/linksquared_production

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------------------
# ActiveRecord Encryption
# Generate with: bin/rails db:encryption:init
# -----------------------------------------------------------------------------
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=your_primary_key_here
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=your_deterministic_key_here
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=your_salt_here

# -----------------------------------------------------------------------------
# AWS S3 (file storage via ActiveStorage)
# -----------------------------------------------------------------------------
AWS_S3_KEY_ID=your_aws_key_id
AWS_S3_ACCESS_KEY=your_aws_secret_key
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
S3_ASSET_PREFIX=http://localhost:3000

# -----------------------------------------------------------------------------
# Email (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your_sendgrid_api_key

# -----------------------------------------------------------------------------
# Payments (Stripe)
# -----------------------------------------------------------------------------
STRIPE_API_KEY=your_stripe_api_key
STRIPE_STANDARD_PRICE_ID=your_stripe_price_id
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# -----------------------------------------------------------------------------
# OAuth / SSO
# -----------------------------------------------------------------------------

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft Office365 OAuth
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------

# Admin API key (used for admin/automation endpoints)
ADMIN_API_KEY=generate_a_secure_random_key

# Diagnostics API key
DIAGNOSTICS_API_KEY=generate_a_secure_random_key

# Webhook authentication key for quota notifications
SENT_QUOTAS_WEBHOOK_KEY=generate_a_secure_random_key

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
PUBLIC_GO_PROJECT_IDENTIFIER=public-go-links
PUBLIC_GO_PROJECT_IDENTIFIER_ID=1
FREE_MAU_COUNT=10000

# Comma-separated instance IDs exempt from billing
# FREE_PASS_PROJECT_IDS=

# -----------------------------------------------------------------------------
# Volume Discounts (optional)
# -----------------------------------------------------------------------------
# FIRST_DISCOUNT_MAUS_THRESHOLD=1000000
# FIRST_DISCOUNT_PERCENTAGE=25
# SECOND_DISCOUNT_MAUS_THRESHOLD=1500000
# SECOND_DISCOUNT_PERCENTAGE=30

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry, optional)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER=otlp
# OTEL_SERVICE_NAME=linksquared-development
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# Deployment (Kamal, optional)
# -----------------------------------------------------------------------------
# KAMAL_REGISTRY_PASSWORD=your_docker_registry_token

# -----------------------------------------------------------------------------
# Default Assets (optional)
# -----------------------------------------------------------------------------
# Fallback logo and social preview image used when apps/links have no custom assets.
# DEFAULT_LOGO_URL=https://your-bucket.s3.region.amazonaws.com/logo.svg
# DEFAULT_SOCIAL_PREVIEW_URL=https://your-bucket.s3.region.amazonaws.com/social-preview.jpg
# DEFAULT_LINK_TITLE=grovs
# DEFAULT_LINK_SUBTITLE=Dynamic links, attributions, and referrals across mobile and web platforms.

# Email template assets (used in mailer views)
# ASSET_LOGO_LARGE_URL=https://your-bucket.s3.region.amazonaws.com/logo-large.png
# ASSET_LOGO_SQUARE_URL=https://your-bucket.s3.region.amazonaws.com/logo-square.png
# ASSET_ATTENTION_ICON_URL=https://your-bucket.s3.region.amazonaws.com/attention-icon.png
# ASSET_DOWNLOAD_ICON_URL=https://your-bucket.s3.region.amazonaws.com/download-icon.png
# ASSET_LINKEDIN_ICON_URL=https://your-bucket.s3.region.amazonaws.com/linkedin.png
# ASSET_GITHUB_ICON_URL=https://your-bucket.s3.region.amazonaws.com/github.png

# -----------------------------------------------------------------------------
# Performance Tuning (optional)
# -----------------------------------------------------------------------------
# WEB_CONCURRENCY=8
# RAILS_MAX_THREADS=32
